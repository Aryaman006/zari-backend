# ── Storage ───────────────────────────────────────────────────────
# STORAGE_BACKEND options:
#   "local"    = local filesystem (default for dev — no credentials needed)
#   "supabase" = Supabase Storage (production — requires SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY)
#   "r2"       = Cloudflare R2 (legacy — requires R2_* credentials)
STORAGE_BACKEND=local
LOCAL_UPLOADS_DIR=uploads
BACKEND_URL=http://localhost:8000

# ── Supabase (set STORAGE_BACKEND=supabase to enable) ─────────────────
# SUPABASE_URL=https://PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_STORAGE_BUCKET=zari-assets

# ── Cloudflare R2 (disabled — set STORAGE_BACKEND=r2 to enable) ──
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=zari-assets
# R2_PUBLIC_URL=

